{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://k-comms.invalid/schemas/message-created.v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "conversation_id",
    "conversation_sequence",
    "sender_user_id",
    "client_message_id",
    "status",
    "inserted_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "conversation_id": {
      "type": "string",
      "format": "uuid"
    },
    "conversation_sequence": {
      "type": "integer",
      "minimum": 1
    },
    "sender_user_id": {
      "type": "string",
      "format": "uuid"
    },
    "sender_device_id": {
      "type": "string",
      "format": "uuid"
    },
    "client_message_id": {
      "type": "string",
      "minLength": 8,
      "maxLength": 128
    },
    "reply_to_message_id": {
      "type": ["string", "null"],
      "format": "uuid"
    },
    "body": {
      "type": ["string", "null"]
    },
    "status": {
      "enum": ["active", "deleted", "moderated"]
    },
    "metadata": {
      "type": "object"
    },
    "edited_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "deleted_at": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "inserted_at": {
      "type": "string",
      "format": "date-time"
    },
    "attachments": {
      "type": "array",
      "items": {"type": "object"}
    },
    "reactions": {
      "type": "array",
      "items": {"type": "object"}
    }
  }
}
