{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Soyuz-Tec/k-comms/blob/main/docs/13-delivery-plan/internal-production-readiness-ledger.schema.json",
  "title": "K-Comms internal production readiness ledger",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "template",
    "generated_at",
    "release",
    "production_ready",
    "decision",
    "gates",
    "signoffs"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "schema_version": {
      "const": 1
    },
    "template": {
      "type": "boolean"
    },
    "generated_at": {
      "$ref": "#/$defs/nullableTimestamp"
    },
    "release": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_revision",
        "image_digest",
        "bundle_sha256",
        "environment_id"
      ],
      "properties": {
        "git_revision": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^[0-9a-f]{40}$"
            }
          ]
        },
        "image_digest": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^sha256:[0-9a-f]{64}$"
            }
          ]
        },
        "bundle_sha256": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^[0-9a-f]{64}$"
            }
          ]
        },
        "environment_id": {
          "anyOf": [
            {
              "type": "null"
            },
            {
              "type": "string",
              "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
            }
          ]
        }
      }
    },
    "production_ready": {
      "type": "boolean"
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "decided_at",
        "expires_at",
        "approver",
        "evidence_uri",
        "notes"
      ],
      "properties": {
        "status": {
          "enum": [
            "pending",
            "approved",
            "rejected"
          ]
        },
        "decided_at": {
          "$ref": "#/$defs/nullableTimestamp"
        },
        "expires_at": {
          "$ref": "#/$defs/nullableTimestamp"
        },
        "approver": {
          "$ref": "#/$defs/nullableActor"
        },
        "evidence_uri": {
          "$ref": "#/$defs/nullableEvidenceUri"
        },
        "notes": {
          "$ref": "#/$defs/notes"
        }
      }
    },
    "gates": {
      "type": "array",
      "minItems": 26,
      "maxItems": 26,
      "items": {
        "$ref": "#/$defs/gate"
      }
    },
    "signoffs": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/signoff"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "template": {
            "const": false
          }
        }
      },
      "then": {
        "properties": {
          "generated_at": {
            "$ref": "#/$defs/timestamp"
          },
          "release": {
            "properties": {
              "git_revision": {
                "type": "string",
                "pattern": "^[0-9a-f]{40}$"
              },
              "image_digest": {
                "type": "string",
                "pattern": "^sha256:[0-9a-f]{64}$"
              },
              "bundle_sha256": {
                "type": "string",
                "pattern": "^[0-9a-f]{64}$"
              },
              "environment_id": {
                "type": "string",
                "pattern": "^[a-z0-9][a-z0-9._/-]{2,127}$"
              }
            }
          }
        }
      }
    }
  ],
  "$defs": {
    "timestamp": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}Z$"
    },
    "nullableTimestamp": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/timestamp"
        }
      ]
    },
    "actor": {
      "type": "string",
      "minLength": 2,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9 ._:/-]*$"
    },
    "nullableActor": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/actor"
        }
      ]
    },
    "evidenceUri": {
      "type": "string",
      "minLength": 8,
      "maxLength": 1024,
      "pattern": "^[A-Za-z][A-Za-z0-9+.-]*://[^?#]+$"
    },
    "nullableEvidenceUri": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/evidenceUri"
        }
      ]
    },
    "notes": {
      "type": "string",
      "maxLength": 2000
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "title",
        "status",
        "owner",
        "approver",
        "assessed_at",
        "review_due_at",
        "evidence_uri",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(application|environment|people)\\.[a-z][a-z0-9_]*$"
        },
        "category": {
          "enum": [
            "application",
            "environment",
            "people"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 4,
          "maxLength": 160
        },
        "status": {
          "enum": [
            "pending",
            "passed",
            "failed",
            "expired"
          ]
        },
        "owner": {
          "$ref": "#/$defs/nullableActor"
        },
        "approver": {
          "$ref": "#/$defs/nullableActor"
        },
        "assessed_at": {
          "$ref": "#/$defs/nullableTimestamp"
        },
        "review_due_at": {
          "$ref": "#/$defs/nullableTimestamp"
        },
        "evidence_uri": {
          "$ref": "#/$defs/nullableEvidenceUri"
        },
        "notes": {
          "$ref": "#/$defs/notes"
        }
      }
    },
    "signoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "role",
        "status",
        "signer",
        "signed_at",
        "evidence_uri",
        "notes"
      ],
      "properties": {
        "role": {
          "enum": [
            "product",
            "accessibility",
            "security",
            "operations",
            "business"
          ]
        },
        "status": {
          "enum": [
            "pending",
            "passed",
            "rejected"
          ]
        },
        "signer": {
          "$ref": "#/$defs/nullableActor"
        },
        "signed_at": {
          "$ref": "#/$defs/nullableTimestamp"
        },
        "evidence_uri": {
          "$ref": "#/$defs/nullableEvidenceUri"
        },
        "notes": {
          "$ref": "#/$defs/notes"
        }
      }
    }
  }
}
