# Import these keys into the externally managed k-comms-secrets Secret.
# Never commit a populated copy. Platform-role management uses a separate
# one-shot operator Secret and is deliberately absent from long-lived runtime pods.
# The PostgreSQL CA is public trust material, not a credential: create the
# k-comms-database-ca ConfigMap from the provider PEM instead of putting it here.
DATABASE_URL=CHANGE_ME
SECRET_KEY_BASE=CHANGE_ME
RELEASE_COOKIE=CHANGE_ME
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
WEBHOOK_SECRET_ENCRYPTION_KEY=CHANGE_ME
PUSH_SUBSCRIPTION_ENCRYPTION_KEY=CHANGE_ME
# Optional zero-downtime rotation keyrings use comma-separated id:Base64Key
# entries named WEBHOOK_SECRET_ENCRYPTION_KEYS and PUSH_SUBSCRIPTION_ENCRYPTION_KEYS.
METRICS_BEARER_TOKEN=CHANGE_ME
PASSWORD_RECOVERY_SIGNING_KEY=CHANGE_ME_AT_LEAST_32_RANDOM_BYTES
