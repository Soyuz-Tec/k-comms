# Copy this file to secrets.env and replace every CHANGE_ME value.
# Never commit secrets.env.
DATABASE_URL=ecto://kcomms:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/k_comms
SECRET_KEY_BASE=CHANGE_ME_GENERATE_WITH_MIX_PHX_GEN_SECRET
PASSWORD_RECOVERY_SIGNING_KEY=CHANGE_ME_GENERATE_AT_LEAST_32_RANDOM_BYTES
RELEASE_COOKIE=CHANGE_ME_GENERATE_A_LONG_RANDOM_RELEASE_COOKIE
S3_ACCESS_KEY_ID=kcomms
S3_SECRET_ACCESS_KEY=CHANGE_ME_MINIO_SECRET
WEBHOOK_SECRET_ENCRYPTION_KEY=CHANGE_ME_GENERATE_32_BYTE_SECRET
PUSH_SUBSCRIPTION_ENCRYPTION_KEY=CHANGE_ME_GENERATE_32_BYTE_SECRET
# Optional zero-downtime rotation keyrings use comma-separated id:Base64Key
# entries named WEBHOOK_SECRET_ENCRYPTION_KEYS and PUSH_SUBSCRIPTION_ENCRYPTION_KEYS.
METRICS_BEARER_TOKEN=CHANGE_ME_GENERATE_LONG_METRICS_TOKEN
POSTGRES_USER=kcomms
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
