# Copy this file to bootstrap-secrets.env and replace every CHANGE_ME value.
# This secret is only used by the one-time bootstrap Job. Delete the local file
# and the Kubernetes Secret immediately after the Job succeeds.
BOOTSTRAP_TENANT_NAME=CHANGE_ME_STAGING_WORKSPACE_NAME
BOOTSTRAP_TENANT_SLUG=CHANGE_ME_STAGING_WORKSPACE_SLUG
BOOTSTRAP_OWNER_DISPLAY_NAME=CHANGE_ME_INITIAL_OWNER_NAME
BOOTSTRAP_OWNER_EMAIL=CHANGE_ME_INITIAL_OWNER_EMAIL
BOOTSTRAP_OWNER_PASSWORD=CHANGE_ME_GENERATE_A_UNIQUE_PASSWORD_OF_AT_LEAST_12_CHARACTERS
