# Create as the short-lived k-comms-platform-role-grant Secret, run the Job,
# then delete both the Secret and Job. Never commit a populated copy.
MANAGEMENT_SECRET=CHANGE_ME_GENERATE_AT_LEAST_32_RANDOM_BYTES
USER_ID=CHANGE_ME_TARGET_USER_UUID
ROLE=platform_operator
TTL_SECONDS=3600
ACTOR=CHANGE_ME_OPERATOR_IDENTITY
REASON=CHANGE_ME_EXPLICIT_APPROVED_REASON
